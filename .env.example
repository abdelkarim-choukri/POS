# Copy this file to `.env` for local development.
# `.env` is gitignored — never commit real secrets.
#
# These values are read by docker-compose.yml automatically.

# ---- Database ----
# When running INSIDE Docker (docker compose up), DATABASE_HOST=postgres
# because the backend container reaches Postgres via the Docker service name.
# When running OUTSIDE Docker (e.g. `pnpm start:dev` directly on your host),
# change DATABASE_HOST to "localhost".
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=pos_user
DATABASE_PASSWORD=pos_password
DATABASE_NAME=pos_db

# ---- Redis ----
# Used for background jobs (BullMQ) and caching. Same host rule as DB:
# "redis" inside Docker, "localhost" outside.
REDIS_HOST=redis
REDIS_PORT=6379

# ---- JWT ----
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# ---- App ----
PORT=3000
NODE_ENV=development
